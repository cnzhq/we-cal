BEGIN:VCALENDAR
VERSION:2.0
PRODID:-//Your Name//Personal Calendar//EN
CALSCALE:GREGORIAN
METHOD:PUBLISH
X-WR-CALNAME:我的日程
X-WR-TIMEZONE:Asia/Shanghai
X-WR-CALDESC:通过 GitHub 同步的个人日历

BEGIN:VTIMEZONE
TZID:Asia/Shanghai
BEGIN:STANDARD
DTSTART:19700101T000000
TZOFFSETFROM:+0800
TZOFFSETTO:+0800
END:STANDARD
END:VTIMEZONE

BEGIN:VEVENT
UID:example-event-001@yourdomain.com
DTSTAMP:20250419T080000Z
DTSTART;TZID=Asia/Shanghai:20250420T100000
DTEND;TZID=Asia/Shanghai:20250420T120000
SUMMARY:示例会议
DESCRIPTION:这是一个示例事件，展示基本的日程格式
LOCATION:线上会议室
STATUS:CONFIRMED
SEQUENCE:0
BEGIN:VALARM
ACTION:DISPLAY
DESCRIPTION:会议提醒
TRIGGER:-PT15M
END:VALARM
END:VEVENT

BEGIN:VEVENT
UID:example-event-002@yourdomain.com
DTSTAMP:20250419T080000Z
DTSTART;VALUE=DATE:20250421
DTEND;VALUE=DATE:20250422
SUMMARY:全天事件示例
DESCRIPTION:这是一个全天事件（无具体时间）
STATUS:CONFIRMED
SEQUENCE:0
END:VEVENT

BEGIN:VEVENT
UID:example-event-003@yourdomain.com
DTSTAMP:20250419T080000Z
DTSTART;TZID=Asia/Shanghai:20250422T140000
DTEND;TZID=Asia/Shanghai:20250422T150000
RRULE:FREQ=WEEKLY;BYDAY=TU;COUNT=10
SUMMARY:每周例会（重复事件）
DESCRIPTION:每周二重复的例会，共10次
LOCATION:会议室A
STATUS:CONFIRMED
SEQUENCE:0
BEGIN:VALARM
ACTION:DISPLAY
DESCRIPTION:例会即将开始
TRIGGER:-PT10M
END:VALARM
END:VEVENT

END:VCALENDAR